# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (docker-compose default below)
DATABASE_URL=postgresql://netpulse:netpulse_dev@localhost:5432/netpulse

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Secret used to sign JWTs for end users and operators
JWT_SECRET=

# Separate secret used ONLY for super admin JWTs (must differ from JWT_SECRET)
JWT_SUPER_ADMIN_SECRET=

# ─── OAuth — Google ───────────────────────────────────────────────────────────
# Google OAuth 2.0 client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=

# ─── OAuth — Facebook ────────────────────────────────────────────────────────
# Facebook App ID (from Meta Developer Portal)
FACEBOOK_APP_ID=
# Facebook App Secret (from Meta Developer Portal)
FACEBOOK_APP_SECRET=

# ─── OAuth — Apple ───────────────────────────────────────────────────────────
# Apple Service ID (client_id for Sign In with Apple)
APPLE_CLIENT_ID=
# Apple Team ID (10-character string from Apple Developer account)
APPLE_TEAM_ID=
# Apple Key ID (from the Sign In with Apple key you created)
APPLE_KEY_ID=
# Apple private key PEM content (from the .p8 file, newlines as \n)
APPLE_PRIVATE_KEY=

# ─── OTP — Africa's Talking ──────────────────────────────────────────────────
# Africa's Talking API key (from dashboard.africastalking.com)
AT_API_KEY=
# Africa's Talking username (your account username)
AT_USERNAME=
# Sender ID registered with Africa's Talking (e.g. NETPULSE)
AT_SENDER_ID=

# ─── Firebase Cloud Messaging ────────────────────────────────────────────────
# Firebase project ID (from Firebase console)
FIREBASE_PROJECT_ID=
# Firebase service account private key (PEM, newlines as \n)
FIREBASE_PRIVATE_KEY=
# Firebase service account client email
FIREBASE_CLIENT_EMAIL=

# ─── Payments — Peach Payments ───────────────────────────────────────────────
# Peach Payments OAuth bearer token
PEACH_PAYMENTS_TOKEN=
# Peach Payments entity ID for the merchant channel
PEACH_PAYMENTS_ENTITY_ID=
# Peach Payments webhook secret for signature verification
PEACH_PAYMENTS_WEBHOOK_SECRET=

# ─── Payments — Bango Carrier Billing ────────────────────────────────────────
# Bango API key
BANGO_API_KEY=
# Bango API secret
BANGO_API_SECRET=
# Bango API base URL
BANGO_API_URL=https://api.bango.net

# ─── MikroTik ────────────────────────────────────────────────────────────────
# Default REST API port for MikroTik routers (RouterOS 7+)
MIKROTIK_DEFAULT_PORT=8728

# ─── Redis ───────────────────────────────────────────────────────────────────
# Redis connection URL (docker-compose default below)
REDIS_URL=redis://localhost:6379

# ─── App ─────────────────────────────────────────────────────────────────────
# Port the Fastify backend listens on
PORT=3000
# Environment: development | test | production
NODE_ENV=development
# Base URL of the backend (used for webhook callbacks, deep links)
API_BASE_URL=http://localhost:3000
